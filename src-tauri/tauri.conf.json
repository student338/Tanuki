{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Tanuki Stories",
  "version": "0.1.0",
  "identifier": "com.tanuki.stories",
  "build": {
    "beforeBuildCommand": "TAURI_BUILD=1 npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "title": "Tanuki Stories",
    "windows": [
      {
        "title": "Tanuki Stories",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "iOS": {},
    "android": {}
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "llama-server",
          "cmd": "binaries/llama-server",
          "args": true
        }
      ]
    }
  }
}
