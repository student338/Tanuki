OPENAI_API_KEY=your-key-here
SESSION_SECRET=replace-with-a-long-random-string

# Optional: admin credentials (defaults shown).
# Supports one admin:
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123
# Or multiple admins (comma-separated; passwords align by position).
# Security note: provide one explicit password per admin to avoid shared fallback passwords.
# ADMIN_USERNAME=admin,principal,supervisor
# ADMIN_PASSWORD=admin123,principal123,supervisor123

# Optional: custom OpenAI-compatible endpoint (can also be set in the Admin UI)
# OPENAI_BASE_URL=http://localhost:11434/v1

# Note: student accounts are managed through the Admin UI or imported via CSV at install.
# See the Admin UI → Student Management section.
